<!--
  Sample Infinispan deployment configuration for applications extending Data Services.

  Defines only the JGroups transport stack. Cache definitions (names, TTL, maxCount)
  are maintained in infinispan-caches.xml (provided by the dataservices-core module)
  and applied automatically by InfinispanCacheConfiguration at startup.

  To add application-specific caches, override infinispan-caches.xml by placing a
  custom version in src/main/resources/ that extends the standard cache definitions.

  JGroups transport uses TCP with DNS_PING for peer discovery in Kubernetes.
  Before deploying to Kubernetes, replace the dns_query value with the headless
  Service name that matches your namespace:
    <namespace> is the Kubernetes namespace where Data Services pods are running.
    Example: dataservices-jgroups.my-namespace.svc.cluster.local

  The default value uses the system property jgroups.dns.query so that the
  query can be overridden at runtime without rebuilding the image:
    -Djgroups.dns.query=dataservices-jgroups.my-namespace.svc.cluster.local

  In single-pod or local-dev mode DNS_PING returns no peers and the node forms
  a cluster of size 1 without errors — no additional configuration is required.
-->
<infinispan xmlns="urn:infinispan:config:15.0">

	<jgroups>
		<stack name="tcp-dns">
			<TCP bind_addr="SITE_LOCAL" bind_port="7800"/>
			<org.jgroups.protocols.dns.DNS_PING dns_query="${jgroups.dns.query:dataservices-jgroups.default.svc.cluster.local}" dns_record_type="A"/>
			<MERGE3/>
			<FD_SOCK2/>
			<FD_ALL3/>
			<VERIFY_SUSPECT2/>
			<pbcast.NAKACK2/>
			<UNICAST3/>
			<pbcast.STABLE/>
			<pbcast.GMS/>
			<MFC/>
			<FRAG4/>
		</stack>
	</jgroups>

	<cache-container>
		<transport cluster="dataservices-cluster" stack="tcp-dns"/>
	</cache-container>

</infinispan>
