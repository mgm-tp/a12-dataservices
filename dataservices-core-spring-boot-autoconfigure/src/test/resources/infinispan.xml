<!--
  Test-only Infinispan deployment configuration — LOCAL mode (no JGroups transport).

  Overrides the production infinispan.xml on the test classpath so that integration
  tests run without requiring a network or Kubernetes DNS. Cache definitions are NOT
  declared here; InfinispanCacheConfiguration detects the absence of transport
  (isClustered() == false) and applies infinispan-caches-local.xml automatically.

  Tests that require clustered (INVALIDATION) behavior use a separate transport XML
  (infinispan-single-pod-test.xml or infinispan-cluster-test.xml) supplied via the
  infinispan.embedded.configXml property in ApplicationContextRunner.
-->
<infinispan xmlns="urn:infinispan:config:15.0">

	<cache-container>
		<!-- No transport element = LOCAL mode -->
	</cache-container>

</infinispan>
