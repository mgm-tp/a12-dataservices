<!--
  Test-only Infinispan deployment configuration for InfinispanCacheIT.shouldStartWithoutErrorsInSinglePodMode.

  Uses TCP + DNS_PING with a non-existent DNS name to simulate a single-pod deployment
  where DNS_PING returns no peers (NXDOMAIN). Verifies that the cluster forms with
  size 1 without errors or JGroupsException being thrown.

  Cache definitions are NOT declared here; InfinispanCacheConfiguration detects
  the presence of transport (isClustered() == true) and applies infinispan-caches.xml
  (INVALIDATION mode) automatically — exercising the same code path as production.
-->
<infinispan xmlns="urn:infinispan:config:15.0">

	<jgroups>
		<stack name="tcp-dns-nopeer">
			<TCP bind_addr="127.0.0.1" bind_port="0"/>
			<org.jgroups.protocols.dns.DNS_PING dns_query="nonexistent.invalid" dns_record_type="A"/>
			<MERGE3/>
			<FD_SOCK2/>
			<FD_ALL3/>
			<VERIFY_SUSPECT2/>
			<pbcast.NAKACK2/>
			<UNICAST3/>
			<pbcast.STABLE/>
			<pbcast.GMS/>
			<MFC/>
			<FRAG4/>
		</stack>
	</jgroups>

	<cache-container>
		<transport cluster="dataservices-test-cluster" stack="tcp-dns-nopeer"/>
	</cache-container>

</infinispan>
