        "value": "admin,systemAdmin"
      }
    ],
    "modelReferences": []
  },
  "content": {
    "modelInfo": {
      "name": "DomainRole",
      "immutable": false,
      "comment": "DomainRole represents mapping between AccessRights and Users"
    },
    "modelConfig": {
      "decimalSeparator": ".",
      "timeZone": "UTC",
      "conditionLanguage": {
        "code": "en_US"
      }
    },
    "modelRoot": {
      "rootGroups": [
        {
          "type": "Group",
          "id": "G2",
          "name": "SystemProperties",
          "Group": {
            "repeatability": 1,
            "elements": [
              {
                "type": "Field",
                "id": "F3",
                "name": "name",
                "Field": {
                  "fieldType": {
                    "type": "StringType",
                    "StringType": {
                      "errorMessage": [
                        {
                          "locale": "de",
                          "text": "Der Name darf nur Buchstaben, Ziffern und Unterstriche enthalten."
                        },
                        {
                          "locale": "en",
                          "text": "The name can only contain letters, numbers and underscore."
                        }
                      ],
                      "pattern": "[a-zA-Z0-9_]*"
                    }
                  },
                  "label": [
                    {
                      "locale": "de",
                      "text": "Name"
                    },
                    {
                      "locale": "en",
                      "text": "Name"
                    }
                  ]
                }
              },
              {
                "type": "Rule",
                "id": "R7",
                "name": "ruleNameRequired",
                "Rule": {
                  "errorEntityRelPath": "../name",
                  "errorCode": "Error R7",
                  "errorCondition": "FieldNotFilled(name)",
                  "severity": "ERROR",
                  "errorMessage": [
                    {
                      "locale": "en",
                      "text": "Name is required."
                    },
                    {
                      "locale": "de",
                      "text": "Name ist ein Pflichtfeld."
                    }
                  ],
                  "guiPatterns": {
                    "dynamicEnumerationRule": "false"
                  }
                }
              },
              {
                "type": "Field",
                "id": "F4",
                "name": "description",
                "Field": {
                  "fieldType": {
                    "type": "StringType",
                    "StringType": {}
                  },
                  "label": [
                    {
                      "locale": "de",
                      "text": "Beschreibung"
                    },
                    {
                      "locale": "en",
                      "text": "description"
                    }
                  ]
                }
              },
              {
                "type": "Rule",
                "id": "R12",
                "name": "ruleAccessRightsRequired",
                "Rule": {
                  "errorEntityRelPath": "../accessRights/accessRightIdent",
                  "errorCode": "Error R12",
                  "errorCondition": "AtLeastOneGroupFilled(accessRights)",
                  "severity": "ERROR",
                  "errorMessage": [
                    {
                      "locale": "de",
                      "text": "Bitte klicken sie auf 'ADD' und wählen Sie ein Zugriffsrecht aus."
                    },
                    {
                      "locale": "en",
                      "text": "Please click 'ADD' and select an access right."
                    }
                  ],
                  "guiPatterns": {
                    "dynamicEnumerationRule": "false"
                  }
                }
              },
              {
                "type": "Group",
                "id": "G5",
                "name": "accessRights",
                "Group": {
                  "repeatability": 10000,
                  "elements": [
                    {
                      "type": "Field",
                      "id": "F6",
                      "name": "accessRightIdent",
                      "Field": {
                        "fieldType": {
                          "type": "StringType",
                          "StringType": {
                            "errorMessage": [
                              {
                                "locale": "de",
                                "text": "Der Name darf nur Buchstaben, Ziffern und Unterstriche enthalten."
                              },
                              {
                                "locale": "en",
                                "text": "The name can only contain letters, numbers and underscore."
                              }
                            ],
                            "pattern": "[a-zA-Z0-9_]*"
                          }
                        },
                        "label": [
                          {
                            "locale": "de",
                            "text": "Zugriffsrecht"
                          },
                          {
                            "locale": "en",
                            "text": "access right"
                          }
                        ]
                      }
                    },
                    {
                      "type": "Rule",
                      "id": "R11",
                      "name": "ruleAccessRightIdentRequired",
                      "Rule": {
                        "errorEntityRelPath": "../accessRightIdent",
                        "errorCode": "Error R11",
                        "errorCondition": "GroupFilled(RuleGroup) AND FieldNotFilled(accessRightIdent)",
                        "severity": "ERROR",
                        "errorMessage": [
                          {
                            "locale": "de",
                            "text": "Bitte wählen sie ein Zugriffsrecht aus."
                          },
                          {
                            "locale": "en",
                            "text": "Please select an access right."
                          }
                        ],
                        "guiPatterns": {
                          "dynamicEnumerationRule": "false"
                        }
                      }
                    }
                  ]
                }
              },
              {
                "type": "Field",
                "id": "F13",
                "name": "existing",
                "Field": {
                  "fieldType": {
                    "type": "BooleanType",
                    "BooleanType": {}
                  },
                  "label": [
                    {
                      "locale": "de",
                      "text": "existierende Rolle"
                    },
                    {
                      "locale": "en",
                      "text": "existing role"
                    }
                  ]
                }
              },
              {
                "type": "Field",
                "id": "F14",
                "name": "documentId",
                "Field": {
                  "fieldType": {
                    "type": "StringType",
                    "StringType": {}
                  },
                  "label": [
                    {
                      "locale": "de",
                      "text": "document id"
                    },
                    {
                      "locale": "en",
                      "text": "document id"
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  }
}
