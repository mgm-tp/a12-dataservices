{
  "header": {
    "modelType": "document",
    "modelVersion": "28.4.0",
    "id": "DomainRole",
    "locales": [
      {
        "code": "en"
      },
      {
        "code": "de"
      }
    ],
    "labels": [],
    "annotations": [
