{
  "header": {
    "id": "DomainAttachmentOnly",
    "modelType": "document",
    "modelVersion": "28.4.0",
    "locales": [
      {
        "code": "en"
      }
    ],
    "labels": [],
    "annotations": [
      {
        "name": "roles",
        "value": "admin"
      }
    ],
    "modelReferences": []
  },
  "content": {
    "modelInfo": {
      "name": "product",
      "immutable": false,
      "comment": "This is a sample product model for a commerce PIM."
    },
    "modelConfig": {
      "decimalSeparator": ".",
      "timeZone": "UTC",
      "conditionLanguage": {
        "code": "en_US"
      }
    },
    "modelRoot": {
      "rootGroups": [
        {
          "type": "Group",
          "id": "G13",
          "name": "Product",
          "Group": {
            "repeatability": 1,
            "elements": [
              {
                "type": "Group",
                "id": "G2",
                "name": "MyAttachment",
                "externalDescription": [
                  {
                    "locale": "en",
                    "text": "External Description Text"
                  }
                ],
                "internalDescription": [
                  {
                    "locale": "en",
                    "text": "Internal Description Text"
                  }
                ],
                "Group": {
                  "repeatability": 1,
                  "usageType": "attachment",
                  "elements": [
                    {
                      "type": "Field",
                      "id": "F3",
                      "name": "original_filename",
                      "Field": {
                        "fieldType": {
                          "type": "StringType"
                        }
                      }
                    },
                    {
                      "type": "Field",
                      "id": "F4",
                      "name": "internal_filename",
                      "Field": {
                        "fieldType": {
                          "type": "StringType"
                        },
                        "requirednessConfig": {
                          "mode": "absoluteOrRelativeToNextRepAncestor"
                        }
                      }
                    },
                    {
                      "type": "Field",
                      "id": "F5",
                      "name": "content",
                      "Field": {
                        "fieldType": {
                          "type": "StringType",
                          "StringType": {
                            "lineBreaksPermitted": true,
                            "noValueValidation": true
                          }
                        }
                      }
                    },
                    {
                      "type": "Field",
                      "id": "F6",
                      "name": "attachment_id",
                      "Field": {
                        "fieldType": {
                          "type": "StringType"
                        }
                      }
                    },
                    {
                      "type": "Field",
                      "id": "F7",
                      "name": "size",
                      "Field": {
                        "fieldType": {
                          "type": "NumberType"
                        }
                      }
                    },
                    {
                      "type": "Field",
                      "id": "F8",
                      "name": "mime_type",
                      "Field": {
                        "fieldType": {
                          "type": "StringType"
                        },
                        "requirednessConfig": {
                          "mode": "absoluteOrRelativeToNextRepAncestor"
                        }
                      }
                    },
                    {
                      "type": "Field",
                      "id": "F9",
                      "name": "category",
                      "Field": {
                        "fieldType": {
                          "type": "StringType"
                        }
                      }
                    },
                    {
                      "type": "Field",
                      "id": "F10",
                      "name": "description",
                      "Field": {
                        "fieldType": {
                          "type": "StringType"
                        }
                      }
                    },
                    {
                      "type": "Rule",
                      "id": "R11",
                      "name": "AttachmentIdOrContentFilled",
                      "Rule": {
                        "errorEntityRelPath": "../content",
                        "errorCode": "Error R11",
                        "errorCondition": "NotExactlyOneFieldFilled(attachment_id, content)",
                        "severity": "ERROR",
                        "errorMessage": [
                          {
                            "locale": "en",
                            "text": "Either attachment_id or content must be filled, but not both."
                          }
                        ],
                        "guiPatterns": {
                          "dynamicEnumerationRule": "false"
                        }
                      }
                    },
                    {
                      "type": "Rule",
                      "id": "R12",
                      "name": "SizeOfContentFilled",
                      "Rule": {
                        "errorEntityRelPath": "../content",
                        "errorCode": "Error R12",
                        "errorCondition": "FieldFilled(content) and FieldNotFilled(size)",
                        "severity": "ERROR",
                        "errorMessage": [
                          {
                            "locale": "en",
                            "text": "If the content is filled, the size must be also filled."
                          }
                        ],
                        "guiPatterns": {
                          "dynamicEnumerationRule": "false"
                        }
                      }
                    }
                  ]
                }
              },
              {
                "type": "Field",
                "id": "F14",
                "name": "Name",
                "Field": {
                  "fieldType": {
                    "type": "StringType"
                  }
                }
              }
            ]
          }
        }
      ]
    }
  }
}
