<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd"
	logicalFilePath="database/schema/20.6.0/model.xml">

	<changeSet id="A12-6853" author="tkupka">
		<dropColumn tableName="ROLE" columnName="PERMISSION"/>

		<createSequence sequenceName="ACCESS_RIGHT_SEQ" startValue="1" incrementBy="1"/>
		<createTable tableName="ACCESS_RIGHT">
			<column name="ID" type="BIGINT" valueSequenceNext="RIGHT_SEQ">
				<constraints primaryKey="true" primaryKeyName="RIGHT_PK"/>
			</column>
			<column name="NAME" type="VARCHAR(500 ${varcharUnit})">
				<constraints unique="true" uniqueConstraintName="RIGHT_UNQ"/>
			</column>
			<column name="DESCRIPTION" type="VARCHAR(1000 ${varcharUnit})"/>
			<column name="CREATED_AT" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP">
				<constraints nullable="false"/>
			</column>
			<column name="MODIFIED_AT" type="TIMESTAMP">
				<constraints nullable="false"/>
			</column>
		</createTable>

		<createTable tableName="ROLE_ACCESS_RIGHT">
			<column name="ACCESS_RIGHT_ID" type="BIGINT"/>
			<column name="ROLE_ID" type="BIGINT"/>
		</createTable>
		<addForeignKeyConstraint constraintName="ROLE_ACCESS_RIGHT_RIGHT_FK" baseColumnNames="ACCESS_RIGHT_ID" baseTableName="ROLE_ACCESS_RIGHT"  referencedTableName="ACCESS_RIGHT" referencedColumnNames="ID"/>
		<addForeignKeyConstraint constraintName="ROLE_ACCESS_RIGHT_ROLE_FK" baseColumnNames="ROLE_ID" baseTableName="ROLE_ACCESS_RIGHT"  referencedTableName="ROLE" referencedColumnNames="ID"/>

		<createIndex tableName="ROLE_ACCESS_RIGHT" indexName="ROLE_ACCESS_RIGHT_ROLE_IDX">
			<column name="ROLE_ID"/>
		</createIndex>
		<createIndex tableName="ROLE_ACCESS_RIGHT" indexName="ROLE_ACCESS_RIGHT_RIGHT_IDX">
			<column name="ACCESS_RIGHT_ID"/>
		</createIndex>
	</changeSet>

	<changeSet id="A12-6850" author="tbajus">
		<addColumn tableName="SERVER_USER">
			<column name="FAILED_LOGIN_AT" type="TIMESTAMP">
				<constraints nullable="true" />
			</column>
		</addColumn>
	</changeSet>
	<changeSet author="tkupka" id="A12-7288">
		<addColumn tableName="SERVER_USER">
			<column name="CLIENT_ID" type="VARCHAR(100 ${varcharUnit})">
				<constraints nullable="true" />
			</column>
		</addColumn>
	</changeSet>

	<changeSet id="A12-7333" author="tkupka">
		<dropTable tableName="DOCUMENT_RELATION"/>
		<dropSequence sequenceName="DOCUMENT_RELATION_SEQ"/>
		<dropTable tableName="DOCUMENT_MODEL_RELATION"/>
		<dropSequence sequenceName="DOCUMENT_MODEL_RELATION_SEQ"/>
	</changeSet>
</databaseChangeLog>
