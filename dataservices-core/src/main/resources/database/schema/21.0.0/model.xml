<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd"
	logicalFilePath="database/schema/21.0.0/model.xml">

	<changeSet id="A12-8935" author="tbajus">
		<dropForeignKeyConstraint baseTableName="UI_MODEL" constraintName="UI_MODEL_DOCUMENT_MODEL_FK" />
		<dropPrimaryKey constraintName="DOCUMET_MODEL_PK" tableName="DOCUMENT_MODEL"/>

		<addNotNullConstraint columnName="NAME" columnDataType="VARCHAR(1024 ${varcharUnit})" tableName="DOCUMENT_MODEL"/>
