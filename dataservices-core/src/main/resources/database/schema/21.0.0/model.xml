		<dropNotNullConstraint tableName="UI_MODEL" columnDataType="INTEGER" columnName="ID" />
		<addPrimaryKey tableName="UI_MODEL" columnNames="NAME" constraintName="UI_MODEL_PK"/>
	</changeSet>
	<changeSet id="A12CORE-9279_2" author="tbajus">
		<preConditions onFail="MARK_RAN">
			<columnExists tableName="UI_MODEL" columnName="document_model_id" />
		</preConditions>
		<dropColumn tableName="UI_MODEL" columnName="document_model_id" />
	</changeSet>
</databaseChangeLog>
