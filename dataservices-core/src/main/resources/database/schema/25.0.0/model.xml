<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd"
	logicalFilePath="database/schema/25.0.0/model.xml">

	<changeSet id="A12S-431" author="tbajus">
		<createSequence sequenceName="RELATIONSHIP_LINK_SEQ" startValue="1" incrementBy="1" />

		<createTable tableName="RELATIONSHIP_LINK">
			<column name="ID" type="BIGINT">
				<constraints primaryKey="true" primaryKeyName="LINK_DESCRIPTOR_PK" nullable="false" />
			</column>
			<column name="RELATIONSHIP_MODEL" type="VARCHAR(500 ${varcharUnit})">
				<constraints nullable="false" />
			</column>
			<column name="ENTITY_ROLE_1" type="VARCHAR(500 ${varcharUnit})">
				<constraints nullable="false" />
			</column>
			<column name="ENTITY_DOCREF_1" type="VARCHAR(500 ${varcharUnit})">
				<constraints nullable="false" />
			</column>
			<column name="ENTITY_ROLE_2" type="VARCHAR(500 ${varcharUnit})">
				<constraints nullable="false" />
			</column>
			<column name="ENTITY_DOCREF_2" type="VARCHAR(500 ${varcharUnit})">
				<constraints nullable="false" />
			</column>
			<column name="LINK_DOCUMENT" type="clob">
				<constraints nullable="true" />
			</column>
		</createTable>

		<update tableName="RELATIONSHIP_LINK">
			<column name="ID" valueSequenceNext="RELATIONSHIP_LINK_SEQ" />
		</update>

		<createIndex tableName="RELATIONSHIP_LINK" indexName="IDX_RELATIONSHIP_MODELL">
			<column name="RELATIONSHIP_MODEL" />
		</createIndex>
		<createIndex tableName="RELATIONSHIP_LINK" indexName="IDX_ENTITY_ROLE_1">
			<column name="ENTITY_ROLE_1" />
		</createIndex>
		<createIndex tableName="RELATIONSHIP_LINK" indexName="IDX_ENTITY_ROLE_2">
			<column name="ENTITY_ROLE_2" />
		</createIndex>
		<createIndex tableName="RELATIONSHIP_LINK" indexName="IDX_ENTITY_DOCREF_1">
			<column name="ENTITY_DOCREF_1" />
		</createIndex>
		<createIndex tableName="RELATIONSHIP_LINK" indexName="IDX_ENTITY_DOCREF_2">
			<column name="ENTITY_DOCREF_2" />
		</createIndex>
	</changeSet>

	<changeSet id="A12S-437" author="tkupka">
		<createTable tableName="RELATIONSHIP_MODEL">
			<column name="NAME" type="VARCHAR(1024 ${varcharUnit})">
				<constraints primaryKey="true" primaryKeyName="RELATIONSHIP_MODEL_PK" nullable="false" />
			</column>
			<column name="MODEL" type="CLOB" />
			<column name="CREATED_BY" type="VARCHAR(100 ${varcharUnit})" />
			<column name="MODIFIED_BY" type="VARCHAR(100 ${varcharUnit})" />
			<column name="CREATED_AT" type="TIMESTAMP" />
			<column name="MODIFIED_AT" type="TIMESTAMP" />
		</createTable>
		<createIndex tableName="RELATIONSHIP_MODEL" indexName="IDX_CREATED_BY">
			<column name="CREATED_BY" />
		</createIndex>
		<createIndex tableName="RELATIONSHIP_MODEL" indexName="IDX_MODIFIED_BY">
			<column name="MODIFIED_BY" />
		</createIndex>
	</changeSet>

	<changeSet id="A12S-437_1" author="tkupka">
		<addForeignKeyConstraint baseTableName="RELATIONSHIP_LINK" constraintName="RELATIONSHIP_MODEL_ID_FK" baseColumnNames="RELATIONSHIP_MODEL"
			referencedTableName="RELATIONSHIP_MODEL" referencedColumnNames="NAME" />
		<addForeignKeyConstraint baseTableName="RELATIONSHIP_LINK" constraintName="ROLE_1_NAME_FK" baseColumnNames="ENTITY_ROLE_1"
			referencedTableName="DOCUMENT_MODEL" referencedColumnNames="NAME" />
		<addForeignKeyConstraint baseTableName="RELATIONSHIP_LINK" constraintName="DOCREF_1_ID_FK" baseColumnNames="ENTITY_DOCREF_1"
			referencedTableName="DOCUMENT" referencedColumnNames="ID" />
		<addForeignKeyConstraint baseTableName="RELATIONSHIP_LINK" constraintName="ROLE_2_NAME_FK" baseColumnNames="ENTITY_ROLE_2"
			referencedTableName="DOCUMENT_MODEL" referencedColumnNames="NAME" />
		<addForeignKeyConstraint baseTableName="RELATIONSHIP_LINK" constraintName="DOCREF_2_ID_FK" baseColumnNames="ENTITY_DOCREF_2"
			referencedTableName="DOCUMENT" referencedColumnNames="ID" />
	</changeSet>

	<changeSet id="A12S-437_2" author="tkupka">
		<dropForeignKeyConstraint baseTableName="RELATIONSHIP_LINK" constraintName="ROLE_1_NAME_FK"/>
		<dropForeignKeyConstraint baseTableName="RELATIONSHIP_LINK" constraintName="ROLE_2_NAME_FK" />
	</changeSet>

	<changeSet id="A12S-526" author="tkupka">
		<addColumn tableName="RELATIONSHIP_LINK">
			<column name="CREATED_AT" type="TIMESTAMP" defaultValueDate="CURRENT_TIMESTAMP">
				<constraints nullable="false"/>
			</column>
		</addColumn>
	</changeSet>

</databaseChangeLog>
