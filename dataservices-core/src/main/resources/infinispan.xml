<!--
  Infinispan deployment configuration for Data Services — production (Kubernetes).

  Defines only the JGroups transport stack. Cache definitions (names, TTL, maxCount)
  are maintained separately in infinispan-caches.xml and applied programmatically
  by InfinispanCacheConfiguration at application startup.

  JGroups transport uses TCP with DNS_PING for peer discovery in Kubernetes.
  The dns_query value must match the headless Service name and namespace:
    dataservices-jgroups.<namespace>.svc.cluster.local
  Override this value per environment using the infinispan.embedded.configXml
  property or by providing a custom infinispan.xml on the classpath.

  In single-pod or local-dev mode DNS_PING returns no peers and the node forms
  a cluster of size 1 without errors.
-->
<infinispan xmlns="urn:infinispan:config:15.0">

	<jgroups>
		<stack name="tcp-dns">
			<TCP bind_addr="SITE_LOCAL" bind_port="7800"/>
			<org.jgroups.protocols.dns.DNS_PING dns_query="dataservices-jgroups.default.svc.cluster.local" dns_record_type="A"/>
			<MERGE3/>
			<FD_SOCK2/>
			<FD_ALL3/>
			<VERIFY_SUSPECT2/>
			<pbcast.NAKACK2/>
			<UNICAST3/>
			<pbcast.STABLE/>
			<pbcast.GMS/>
			<MFC/>
			<FRAG4/>
		</stack>
	</jgroups>

	<cache-container>
		<transport cluster="dataservices-cluster" stack="tcp-dns"/>
	</cache-container>

</infinispan>
