<!--
  Infinispan cache definitions for Data Services.

  Defines all named caches with their eviction properties (TTL, maxCount). The
  cache mode (INVALIDATION_SYNC in a cluster, LOCAL without transport) is set
  programmatically by InfinispanCacheConfiguration based on whether transport
  is configured — the element type here does not affect runtime behavior.

  The deployment-specific JGroups stack and transport element are configured
  separately in infinispan.xml (or a custom override) and must not appear here.

  Cache TTL values (lifespan in ms): -1 = no expiry.
  memory max-count: maximum number of entries per cache; oldest entries are
  evicted when the limit is exceeded.
  Calibrate max-count values in staging using GET /actuator/caches.
-->
<infinispan xmlns="urn:infinispan:config:15.0">

	<cache-container default-cache="default">

		<!-- Default cache: general-purpose fallback for any cache without explicit configuration -->
		<invalidation-cache name="default" statistics="true">
			<expiration lifespan="1200000"/>
			<memory max-count="200"/>
		</invalidation-cache>

		<!-- Validation cache: document model validation results (TTL: 1 hour) -->
		<invalidation-cache name="validationCache" statistics="true">
			<expiration lifespan="3600000"/>
			<memory max-count="500"/>
		</invalidation-cache>

		<!-- Secured model read cache: security-filtered model reads (TTL: 10 hours) -->
		<!-- Evicted cluster-wide on security model update via cache.invalidate() -->
		<invalidation-cache name="securedModelReadCache" statistics="true">
			<expiration lifespan="36000000"/>
			<memory max-count="200"/>
		</invalidation-cache>

		<!-- Generic model read cache (TTL: 10 hours) -->
		<invalidation-cache name="com.mgmtp.a12.dataservices.model.GenericModel" statistics="true">
			<expiration lifespan="36000000"/>
			<memory max-count="100"/>
		</invalidation-cache>

		<!-- Document model read cache (TTL: 10 hours) -->
		<invalidation-cache name="com.mgmtp.a12.kernel.md.model.api.IDocumentModel" statistics="true">
			<expiration lifespan="36000000"/>
			<memory max-count="100"/>
		</invalidation-cache>

		<!-- Relationship model read cache (TTL: 10 hours) -->
		<invalidation-cache name="com.mgmtp.a12.dataservices.relationship.model.RelationshipModel" statistics="true">
			<expiration lifespan="36000000"/>
			<memory max-count="100"/>
		</invalidation-cache>

		<!-- Compose document model read cache (TTL: 10 hours) -->
		<invalidation-cache name="com.mgmtp.a12.dataservices.cdd.jms.internal.ComposeDocumentModel" statistics="true">
			<expiration lifespan="36000000"/>
			<memory max-count="200"/>
		</invalidation-cache>

		<!-- Document model indexed fields cache: derived structural data, no TTL -->
		<invalidation-cache name="documentModelIndexedFieldsCache" statistics="true">
			<expiration lifespan="-1"/>
			<memory max-count="200"/>
		</invalidation-cache>

		<!-- Document model is-indexed-field lookup cache: no TTL -->
		<invalidation-cache name="documentModelIsIndexedFieldCache" statistics="true">
			<expiration lifespan="-1"/>
			<memory max-count="500"/>
		</invalidation-cache>

		<!-- Model graph cache: model type hierarchy (TTL: 24 hours) -->
		<invalidation-cache name="modelGraphCache" statistics="true">
			<expiration lifespan="86400000"/>
			<memory max-count="100"/>
		</invalidation-cache>

		<!-- Model sub-types map cache: model hierarchy subtypes (TTL: 24 hours) -->
		<invalidation-cache name="modelSubTypesMapCache" statistics="true">
			<expiration lifespan="86400000"/>
			<memory max-count="100"/>
		</invalidation-cache>

		<!-- Document model search service cache: no TTL -->
		<invalidation-cache name="documentModelSearchServiceCache" statistics="true">
			<expiration lifespan="-1"/>
			<memory max-count="200"/>
		</invalidation-cache>

		<!-- User cache: authenticated user details, no TTL (invalidated on logout) -->
		<invalidation-cache name="userCache" statistics="true">
			<expiration lifespan="-1"/>
			<memory max-count="200"/>
		</invalidation-cache>

		<!-- Token cache: authentication tokens (TTL: 24 hours) -->
		<invalidation-cache name="tokenCache" statistics="true">
			<expiration lifespan="86400000"/>
			<memory max-count="50"/>
		</invalidation-cache>

		<!-- Role mapping cache: user role assignments (TTL: 24 hours) -->
		<invalidation-cache name="roleMapping" statistics="true">
			<expiration lifespan="86400000"/>
			<memory max-count="100"/>
		</invalidation-cache>

	</cache-container>

</infinispan>
