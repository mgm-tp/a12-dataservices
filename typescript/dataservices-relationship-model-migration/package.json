{
	"name": "@com.mgmtp.a12.dataservices/dataservices-relationship-model-migration",
	"version": "38.4.2-SNAPSHOT",
	"description": "Relationship Model Migration Tool",
	"license": "(EUPL-1.2 OR LicenseRef-commercial)",
	"author": "mgm technology partners",
	"main": "lib/api.js",
	"types": "lib/api.d.ts",
	"type": "module",
	"bin": {
		"relationship-model-migration": "./bin/relationship-model-migration"
	},
	"files": [
		"bin",
		"lib",
		"LICENSE",
		"NOTICE",
		"THIRD_PARTY_NOTICES",
		"licenses",
		"src",
		"cyclonedx.json"
	],
	"scripts": {
		"clean": "rimraf ./lib ./package-lock.json ./target",
		"start": "tsc --watch --preserveWatchOutput",
		"compile": "migration-tool-utils compile",
		"initialize": "node --run format",
		"format": "prettier \"./{src,test}/**/*.ts\" --check",
		"test": "node --run test:consistency && node --run test:steps && node --run test:steps:update-snapshot",
		"test:consistency": "migration-tool-utils validate-consistency",
		"test:steps": "c8 node --run jest",
		"test:steps:update-snapshot": "node --run jest -- --updateSnapshot",
		"generate-step": "migration-tool-utils generate-step",
		"lint:fix": "eslint --fix",
		"format:fix": "prettier \"./{src,test}/**/*.ts\" --write",
		"setVersion": "npm version",
		"jest": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand"
	},
	"jest": {
		"extensionsToTreatAsEsm": [
			".ts"
		],
		"transform": {
			"^.+\\.(t|j)s$": "@swc/jest"
		},
		"roots": [
			"src",
			"test"
		],
		"snapshotFormat": {
			"printBasicPrototype": false
		},
		"reporters": [
			"default",
			"jest-junit"
		]
	},
	"jest-junit": {
		"suiteName": "DataServices Relationship Model Migration Tests",
		"outputDirectory": "./tests",
		"outputName": "TEST-dataservices-relationship-model-migration.xml",
		"uniqueOutputName": "false",
		"classNameTemplate": "{classname}-{title}",
		"titleTemplate": "{classname}-{title}",
		"ancestorSeparator": " › ",
		"usePathForSuiteName": "true"
	},
	"dependencies": {
		"@com.mgmtp.a12.migrationtool/migrationtool-core": "2.1.1"
	},
	"devDependencies": {
		"@com.mgmtp.a12.base/base-model-api": "29.3.0",
		"@com.mgmtp.a12.devtools/tsconfig": "^1.1.0",
		"@com.mgmtp.a12.devtools/eslint-config": "^3.1.0",
		"@com.mgmtp.a12.devtools/prettier-config": "^1.1.0",
		"@com.mgmtp.a12.migrationtool/migrationtool-utils": "2.1.1",
		"@com.mgmtp.a12.utils/utils-localization": "^7.2.0",
		"@swc/core": "^1.11.13",
		"@swc/jest": "^0.2.37",
		"@types/jest": "^29.5.14",
		"@types/node": "^22.13.14",
		"c8": "^10.1.3",
		"eslint": "^9.23.0",
		"eslint-plugin-import": "2.31.0",
		"eslint-plugin-notice": "^1.0.0",
		"eslint-plugin-prettier": "^5.2.5",
		"eslint-plugin-unused-imports": "^4.1.4",
		"jest": "^29.7.0",
		"jest-junit": "^16.0.0",
		"prettier": "^3.5.3",
		"rimraf": "^6.0.1",
		"ts-jest": "^29.3.0",
		"ts-node": "^10.9.2",
		"typescript": "5.8.2"
	}
}
