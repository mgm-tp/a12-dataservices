	field('"Location" as field_c51b9 <<StringType>>')
	group_48575 -- field_c51b9
	field('"Street" as field_7bc6c <<StringType>>')
	group_48575 -- field_7bc6c
	field('"HouseNumber" as field_38cf3 <<StringType>>')
	group_48575 -- field_38cf3
	field('"City" as field_42965 <<StringType>>')
	group_48575 -- field_42965
	field('"PostCode" as field_623a3 <<StringType>>')
	group_48575 -- field_623a3
	field('"Country" as field_804c7 <<StringType>>')
